{
  "name": "groceries-budget-za",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-prisma-provider.mjs && prisma generate && next dev --hostname 0.0.0.0",
    "build": "node scripts/sync-prisma-provider.mjs && prisma generate && next build",
    "vercel-build": "node scripts/sync-prisma-provider.mjs && prisma generate && next build",
    "start": "next start --hostname 0.0.0.0",
    "lint": "next lint",
    "db:push": "node scripts/sync-prisma-provider.mjs && prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "node scripts/sync-prisma-provider.mjs && prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.511.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "prisma": "^6.8.2",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
