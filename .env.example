# --- Local (default) — SQLite file ---
DATABASE_URL="file:./dev.db"

# --- Vercel / production — Postgres (Neon) ---
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# --- Local Postgres (optional) — run: docker compose up -d ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/groceries?schema=public"

# Live prices from store websites. Set to 0 to show "Live price unavailable" only.
LIVE_STORE_LOOKUP=1
STORE_LOOKUP_CACHE_HOURS=6

# If live lookup fails with UNABLE_TO_VERIFY_LEAF_SIGNATURE on Windows, use: npm run dev
# (dev script enables Node --use-system-ca automatically)
