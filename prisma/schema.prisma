generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma-household"
}

// DATABASE_URL = pooled (app + Vercel). DIRECT_URL = direct (Prisma migrate) — see .env.example.
datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Settings {
  id            String @id @default("default")
  monthlyBudget Float  @default(5000)
}

model Store {
  id            String         @id @default(cuid())
  name          String         @unique
  color         String         @default("#16a34a")
  catalogPrices CatalogPrice[]
  purchases     Purchase[]
  receipts      Receipt[]
}

model Product {
  id            String         @id @default(cuid())
  name          String
  brand         String?
  department    String?
  category      String         @default("General")
  size          String?
  unit          String         @default("each")
  aliases       String?
  barcode       String?        @unique
  image         String?
  searchTerms   String?
  updatedAt     DateTime       @updatedAt
  catalogPrices CatalogPrice[]
  purchases     Purchase[]
  receiptItems  ReceiptItem[]
  monthlyNeeds  MonthlyNeed[]

  @@index([name])
  @@index([brand])
  @@index([department])
  @@index([category])
}

model CatalogPrice {
  id           String    @id @default(cuid())
  productId    String
  storeId      String
  price        Float
  specialPrice Float?
  regularPrice Float?
  pricePerUnit Float?
  pricePerUnitUnit String?
  specialLabel String?
  specialUntil DateTime?
  listingName  String?
  image        String?
  updatedAt    DateTime  @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([productId, storeId])
}

model Purchase {
  id        String   @id @default(cuid())
  productId String
  storeId   String
  quantity  Float    @default(1)
  unitPrice Float
  total     Float
  date      DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([productId])
}

model Receipt {
  id         String        @id @default(cuid())
  storeId    String
  date       DateTime      @default(now())
  rawText    String?
  photoCount Int           @default(1)
  createdAt  DateTime      @default(now())
  store      Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items      ReceiptItem[]

  @@index([storeId])
  @@index([date])
}

model ReceiptItem {
  id         String   @id @default(cuid())
  receiptId  String
  productId  String?
  purchaseId String?
  name       String
  quantity   Float    @default(1)
  unitPrice  Float
  total      Float
  createdAt  DateTime @default(now())
  receipt    Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([receiptId])
  @@index([productId])
}

model MonthlyNeed {
  id               String  @id @default(cuid())
  productId        String  @unique
  quantityPerMonth Float   @default(1)
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}
